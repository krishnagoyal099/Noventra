# ═══════════════════════════════════════════════════════════════
#  Noventra — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git — it contains private keys.
# ═══════════════════════════════════════════════════════════════

# ─── Somnia Testnet RPC ───
SOMNIA_RPC_URL=https://dream-rpc.somnia.network

# ─── Deployer Wallet (used to bootstrap agent registry) ───
PRIVATE_KEY=0x_your_deployer_private_key_here
DEPLOYER_PRIVATE_KEY=0x_your_deployer_private_key_here

# ─── Agent Wallet Private Keys ───
# Each agent needs its own funded wallet on Somnia Testnet.
# Fund each from the Somnia faucet: https://testnet.somnia.network/
SCOUT_PRIVATE_KEY=0x_scout_wallet_private_key
RISK_PRIVATE_KEY=0x_risk_wallet_private_key
STRATEGY_PRIVATE_KEY=0x_strategy_wallet_private_key
EXECUTION_PRIVATE_KEY=0x_execution_wallet_private_key
COORDINATOR_PRIVATE_KEY=0x_coordinator_wallet_private_key

# ─── LLM Reasoning (Groq — FinAgent Integration) ───
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key-here

# ─── Deployed Contract Addresses (Somnia Testnet) ───
# These are already hardcoded in scripts — provided here for reference.
# AgentRegistry:  0x2FEAb61eA02604B72D6A7A66D7fc2ca926E9f5E7
# MessageBus:     0x599312a994e130f2201D8De2cE2216d2A7848a98
# ALOCore:        0x6513684C358cD6d92Ad43225Ad9B8e3B81f01398
# MockDEX:        0x6AD7a0e21A997708657FeB019CbE10913AE4165a
# YieldPoolAlpha: 0xF9a098ddd8F8176c86e63606875a99668fD56090
# YieldPoolBeta:  0xEcFe3093addA39C64E6B55804cdCDF657de2f6E9

# ─── Frontend Overrides (optional — for custom deployments) ───
# If you deploy your own contracts, set these in frontend/.env.local
# to point the dashboard at your new addresses.
# VITE_ALO_CORE_ADDRESS=0x_your_deployed_alocore_address
# VITE_MESSAGE_BUS_ADDRESS=0x_your_deployed_messagebus_address